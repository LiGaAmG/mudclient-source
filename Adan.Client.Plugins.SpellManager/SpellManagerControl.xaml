<UserControl x:Class="Adan.Client.Plugins.SpellManager.SpellManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400"
             d:DesignWidth="600"
             Focusable="False"
             Background="#FF1E1E1E"
             Foreground="White"
             MinWidth="400"
             MinHeight="100">
    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="RowBackground" Value="#FF252525"/>
            <Setter Property="AlternatingRowBackground" Value="#FF2D2D2D"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FF3A3A3A"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#FF2D2D2D"/>
                        <Setter Property="Foreground" Value="#FFAAAAAA"/>
                        <Setter Property="BorderBrush" Value="#FF444444"/>
                        <Setter Property="Padding" Value="4,2"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF0055AA"/>
                    <Setter Property="BorderBrush" Value="#FF0055AA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar: title + buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#FF252525" Margin="0,0,0,2">
            <TextBlock Text="Заклинания" Foreground="White" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="8,4"/>
            <Button x:Name="ExecutePlanButton" Content="Заучить по плану"
                    Click="ExecutePlanButton_Click"/>
            <Button x:Name="ForgetAndRememorizeButton" Content="Забыть и перезаучить"
                    Click="ForgetAndRememorizeButton_Click"/>
            <Button x:Name="ClearListButton" Content="Очистить список"
                    Click="ClearListButton_Click"/>
            <TextBlock Text="Префикс:" Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="8,0,3,0"/>
            <TextBox Text="{Binding SpellPrefix, UpdateSourceTrigger=PropertyChanged}"
                     Width="28" MaxLength="2"
                     Background="#FF2A2A2A" Foreground="White" BorderBrush="#FF555555"
                     VerticalContentAlignment="Center" Padding="3,1"
                     ToolTip="Спецсимвол для точного совпадения имени (обычно ! . или ,)"/>
        </StackPanel>

        <!-- Slots row -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Background="#FF2A2A2A" Margin="0,0,0,2">
            <TextBlock Text="Слоты: " Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="6,3"/>
            <TextBlock Text="{Binding FreeSlotsDisplay}" Foreground="#FF88DDFF"
                       VerticalAlignment="Center" Margin="0,3" FontFamily="Courier New" FontSize="11"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  x:Name="SpellsGrid"
                  ItemsSource="{Binding Spells}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  Focusable="False"
                  IsTabStop="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Заклинание" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Кр" Binding="{Binding Circle}" Width="35" IsReadOnly="True"/>
                <DataGridTextColumn Header="Заучено" Binding="{Binding Memorized}" Width="65" IsReadOnly="True"/>
                <DataGridTextColumn Header="Учится" Binding="{Binding Memorizing}" Width="60" IsReadOnly="True"/>
                <DataGridTextColumn Header="Нужно" Binding="{Binding Desired, UpdateSourceTrigger=PropertyChanged}" Width="60">
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="#FF1E1E1E"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Приор" Binding="{Binding Priority, UpdateSourceTrigger=PropertyChanged}" Width="52">
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="#FF1E1E1E"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Счётчик" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsTrackedInCounter, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      HorizontalAlignment="Center" Focusable="False"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Глоб" Width="55">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsTrackedGlobally, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      HorizontalAlignment="Center" Focusable="False"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>

<UserControl x:Class="Adan.Client.Plugins.SpellManager.SpellCounterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="200"
             d:DesignWidth="160"
             Focusable="False"
             Background="#FF1E1E1E"
             Foreground="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок с кнопками A- / A+ -->
        <DockPanel Grid.Row="0" Background="#FF252525">
            <Button DockPanel.Dock="Right" Content="A+" Click="IncreaseFontSize_Click"
                    Width="22" Height="16" Margin="2,1" Padding="0"
                    FontSize="9" Focusable="False"
                    Background="#FF3A3A3A" Foreground="White" BorderBrush="#FF555555"/>
            <Button DockPanel.Dock="Right" Content="A-" Click="DecreaseFontSize_Click"
                    Width="22" Height="16" Margin="2,1" Padding="0"
                    FontSize="9" Focusable="False"
                    Background="#FF3A3A3A" Foreground="White" BorderBrush="#FF555555"/>
            <TextBlock Text="Заклинания" Foreground="#FFAAAAAA"
                       FontSize="10" Margin="4,2" FontWeight="Bold" VerticalAlignment="Center"/>
            <!-- Отладочный индикатор флага _bgInSection: жёлтый = секция активна, серый = нет -->
            <Ellipse Width="8" Height="8" Margin="2,0,4,0" VerticalAlignment="Center"
                     ToolTip="Флаг парсинга зауч/закл (жёлтый = активен)">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="#FF444444"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInSection}" Value="True">
                                <Setter Property="Fill" Value="#FFDDCC00"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
        </DockPanel>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Spells}" Margin="4,0,4,4">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTrackedInCounter}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{Binding Name}" Foreground="White"
                                   FontSize="{Binding DataContext.CounterFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" : " Foreground="#FF666666"
                                   FontSize="{Binding DataContext.CounterFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Memorized}" Foreground="#FF88FF88"
                                   FontSize="{Binding DataContext.CounterFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontWeight="Bold" VerticalAlignment="Center"
                                   MinWidth="20"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>

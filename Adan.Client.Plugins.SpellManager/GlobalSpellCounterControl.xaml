<UserControl x:Class="Adan.Client.Plugins.SpellManager.GlobalSpellCounterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False"
             Background="#FF1E1E1E"
             Foreground="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Background="#FF252525">
            <Button DockPanel.Dock="Right" Content="A+" Click="IncreaseFontSize_Click"
                    Width="22" Height="16" Margin="2,1" Padding="0"
                    FontSize="9" Focusable="False"
                    Background="#FF3A3A3A" Foreground="White" BorderBrush="#FF555555"/>
            <Button DockPanel.Dock="Right" Content="A-" Click="DecreaseFontSize_Click"
                    Width="22" Height="16" Margin="2,1" Padding="0"
                    FontSize="9" Focusable="False"
                    Background="#FF3A3A3A" Foreground="White" BorderBrush="#FF555555"/>
            <TextBlock Text="Все заклинания" Foreground="#FFAAAAAA"
                       FontSize="10" Margin="4,2" FontWeight="Bold" VerticalAlignment="Center"/>
        </DockPanel>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}" Margin="4,2,4,4">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding DisplayName}" Foreground="#FF88AAFF"
                                   FontSize="{Binding DataContext.CounterFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" " Foreground="#FF666666"
                                   FontSize="{Binding DataContext.CounterFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SpellName}" Foreground="White"
                                   FontSize="{Binding DataContext.CounterFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" : " Foreground="#FF666666"
                                   FontSize="{Binding DataContext.CounterFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Memorized}" Foreground="#FF88FF88"
                                   FontSize="{Binding DataContext.CounterFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontWeight="Bold" VerticalAlignment="Center"
                                   MinWidth="20"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>

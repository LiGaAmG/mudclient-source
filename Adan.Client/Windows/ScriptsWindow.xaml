<Window x:Class="Adan.Client.Windows.ScriptsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Scripts" Height="650" Width="1100" MinHeight="400" MinWidth="700"
        Background="#1E1E1E" Foreground="#D4D4D4">
    <Window.Resources>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="ScriptListItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="Padding" Value="4,3"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2D2E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top" Background="#2D2D2D">
            <ToolBar Background="#2D2D2D" Foreground="#D4D4D4">
                <Button Style="{StaticResource ToolBtn}" Click="HandleNewClick" ToolTip="Новый скрипт">+ Новый</Button>
                <Button Style="{StaticResource ToolBtn}" Click="HandleDeleteClick" ToolTip="Удалить выбранный">Удалить</Button>
                <Separator/>
                <Button Style="{StaticResource ToolBtn}" Click="HandleSaveClick" ToolTip="Сохранить (Ctrl+S)">💾 Сохранить</Button>
                <Button Style="{StaticResource ToolBtn}" Click="HandleReloadFolderClick" ToolTip="Обновить список файлов">↺ Обновить</Button>
                <Separator/>
                <CheckBox x:Name="AutoreloadCheck" Foreground="#D4D4D4" VerticalAlignment="Center"
                          Margin="4,0" Checked="HandleAutoreloadChanged" Unchecked="HandleAutoreloadChanged">
                    Autoreload
                </CheckBox>
                <Separator/>
                <Button Style="{StaticResource ToolBtn}" Click="HandleStartAllClick">▶ Старт на всех табах</Button>
                <Button Style="{StaticResource ToolBtn}" Click="HandleStopAllClick">■ Стоп на всех табах</Button>
                <Separator/>
                <TextBlock VerticalAlignment="Center" Foreground="#888" Margin="4,0" x:Name="FolderLabel"
                           ToolTip="Папка скриптов"/>
            </ToolBar>
        </ToolBarTray>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="180"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: script list + controls -->
            <DockPanel Grid.Column="0" Background="#252526">
                <!-- Tab checkboxes for selected script -->
                <Border DockPanel.Dock="Bottom" Background="#2D2D2D" BorderBrush="#444" BorderThickness="0,1,0,0" Padding="6">
                    <StackPanel>
                        <CheckBox x:Name="SharedCheck" Foreground="#D4D4D4" FontWeight="Bold"
                                  Margin="0,0,0,6" Checked="HandleSharedChanged" Unchecked="HandleSharedChanged">
                            Shared (все табы)
                        </CheckBox>
                        <CheckBox x:Name="AutoStartCheck" Foreground="#D4D4D4"
                                  Margin="0,0,0,4" Checked="HandleAutoStartChanged" Unchecked="HandleAutoStartChanged">
                            Авто-старт при коннекте
                        </CheckBox>
                        <TextBlock Foreground="#888" FontSize="11" Margin="0,4,0,2">Запускать на табах:</TextBlock>
                        <ItemsControl x:Name="TabCheckList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" Tag="{Binding Uid}"
                                              Foreground="#D4D4D4" Margin="0,1"
                                              IsChecked="{Binding IsEnabled}"
                                              Checked="HandleTabEnableChanged"
                                              Unchecked="HandleTabEnableChanged"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Script list -->
                <ListBox x:Name="ScriptList" Background="#252526" BorderThickness="0"
                         SelectionChanged="HandleScriptSelected"
                         ItemContainerStyle="{StaticResource ScriptListItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center"
                                         Fill="{Binding StatusColor}"/>
                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                                <TextBlock Text=" [S]" Foreground="#569CD6" FontSize="10" VerticalAlignment="Center"
                                           Visibility="{Binding SharedVisible}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#333"/>

            <!-- Right: AvalonEdit -->
            <DockPanel Grid.Column="2" Background="#1E1E1E">
                <TextBlock DockPanel.Dock="Top" x:Name="EditorFileLabel" Foreground="#888"
                           Padding="8,4" Background="#252526" FontFamily="Consolas"/>
                <avalon:TextEditor x:Name="CodeEditor"
                                   FontFamily="Consolas" FontSize="13"
                                   Background="#1E1E1E" Foreground="#D4D4D4"
                                   LineNumbersForeground="#858585"
                                   ShowLineNumbers="True"
                                   WordWrap="False"
                                   SyntaxHighlighting="Lua"/>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>

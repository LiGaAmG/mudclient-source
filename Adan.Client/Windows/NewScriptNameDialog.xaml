<Window x:Class="Adan.Client.Windows.NewScriptNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый скрипт" Height="120" Width="350"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#2D2D2D" Foreground="#D4D4D4">
    <StackPanel Margin="12">
        <TextBlock Text="Имя файла (.lua):" Foreground="#D4D4D4" Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox" Background="#1E1E1E" Foreground="#D4D4D4"
                 BorderBrush="#555" Padding="4" KeyDown="HandleKeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Создать" Width="70" Margin="0,0,6,0"
                    Background="#0E639C" Foreground="White" BorderThickness="0"
                    Click="HandleOkClick"/>
            <Button Content="Отмена" Width="70"
                    Background="#3C3C3C" Foreground="#D4D4D4" BorderBrush="#555"
                    IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>

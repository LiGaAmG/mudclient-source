<Window x:Class="Adan.Client.Dialogs.ConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect to server..."
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Width="380"
        Height="250"
        Style="{StaticResource DefaultWindowStyle}">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="5"/>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="5" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="5" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="5" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="5" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Label Content="Host name:"
               Grid.Column="0"
               Grid.Row="0"
               VerticalAlignment="Center"/>
        <TextBox Text="{Binding HostName}"
                 Grid.Row="0"
                 Grid.Column="1"
                 HorizontalAlignment="Stretch"
                 Margin="5,0,0,0"/>

        <Label Content="Port:"
               Grid.Column="0"
               Grid.Row="2"
               VerticalAlignment="Center" />
        <TextBox Text="{Binding Port}"
                 Grid.Row="2"
                 Grid.Column="1"
                 HorizontalAlignment="Stretch"
                 Margin="5,0,0,0"/>

        <Border Grid.Row="4" Grid.ColumnSpan="2" BorderBrush="Gray" BorderThickness="0,0,0,1" Margin="0,3,0,0"/>

        <Label Content="SOCKS5 Proxy:"
               Grid.Column="0"
               Grid.Row="6"
               VerticalAlignment="Center"
               FontWeight="Bold"/>

        <Label Content="Proxy host:"
               Grid.Column="0"
               Grid.Row="8"
               VerticalAlignment="Center"/>
        <TextBox Text="{Binding ProxyHost}"
                 Grid.Row="8"
                 Grid.Column="1"
                 HorizontalAlignment="Stretch"
                 Margin="5,0,0,0"/>

        <Label Content="Proxy port:"
               Grid.Column="0"
               Grid.Row="10"
               VerticalAlignment="Center" />
        <TextBox Text="{Binding ProxyPort}"
                 Grid.Row="10"
                 Grid.Column="1"
                 HorizontalAlignment="Stretch"
                 Margin="5,0,0,0"/>

        <StackPanel Grid.Row="12"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button MinWidth="70"
                    Click="HandleCheckProxyClicked"
                    Margin="0,0,5,0">Check proxy</Button>
            <Button IsDefault="True"
                    MinWidth="50"
                    Click="HandleOkClicked">Ok</Button>
            <Button IsCancel="True"
                    MinWidth="50"
                    Margin="5,0,0,0">Cancel</Button>
        </StackPanel>
    </Grid>
</Window>
